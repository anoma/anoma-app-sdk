{
  "name": "@anoma/anomapay-sdk",
  "version": "0.7.1",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "types": "./dist/index.d.cts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "files": [
    "./dist/*"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./api": {
      "import": "./dist/api.mjs",
      "require": "./dist/api.cjs"
    },
    "./constants": {
      "import": "./dist/constants.mjs",
      "require": "./dist/constants.cjs"
    },
    "./domain": {
      "import": "./dist/domain.mjs",
      "require": "./dist/domain.cjs"
    },
    "./lib": {
      "import": "./dist/lib.mjs",
      "require": "./dist/lib.cjs"
    },
    "./types": {
      "import": "./dist/types.mjs",
      "require": "./dist/types.cjs"
    },
    "./wasm": {
      "import": "./dist/wasm.mjs",
      "require": "./dist/wasm.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "rimraf dist",
    "prebuild": "npm run clean && node -p \"'export const ANOMAPAY_SDK_VERSION = ' + JSON.stringify(require('./package.json').version) + ';'\" > src/version.ts",
    "build": "tsdown",
    "build:docs": "typedoc --plugin typedoc-plugin-markdown --out ./docs src/index.ts",
    "build:wasm": "node ./scripts/build.mjs --release",
    "build:wasm:dev": "node ./scripts/build.mjs",
    "lint": "eslint .",
    "tsc": "tsc -b",
    "tsc-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json,md}\"",
    "test": "vitest",
    "prepare": "husky"
  },
  "dependencies": {
    "@noble/hashes": "1.8.0",
    "@noble/secp256k1": "3.0.0",
    "@uniswap/permit2-sdk": "1.4.0",
    "bs58": "^6.0.0",
    "crc-32": "1.2.2",
    "viem": "2.38.5",
    "wagmi": "3.1.1",
    "zod": "4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "eslint": "^9.36.0",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "prettier": "^3.6.2",
    "prettier-plugin-organize-imports": "^4.3.0",
    "rimraf": "^6.1.3",
    "tsdown": "^0.21.5",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.10.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.45.0",
    "vite": "^7.1.7",
    "vite-plugin-dts": "^4.5.4",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.6"
  },
  "publishConfig": {
    "access": "public"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "inlinedDependencies": {
    "abitype": "1.1.0"
  }
}
