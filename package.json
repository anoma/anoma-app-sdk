{
  "name": "@anomaorg/anoma-app-sdk",
  "version": "0.13.1",
  "type": "module",
  "main": "dist/index.js",
  "private": false,
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22"
  },
  "files": [
    "./dist/*",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./api": {
      "import": "./dist/api.js",
      "require": "./dist/api.cjs"
    },
    "./constants": {
      "import": "./dist/lib-constants.js",
      "require": "./dist/lib-constants.cjs"
    },
    "./domain": {
      "import": "./dist/domain.js",
      "require": "./dist/domain.cjs"
    },
    "./lib": {
      "import": "./dist/lib.js",
      "require": "./dist/lib.cjs"
    },
    "./types": {
      "import": "./dist/types.js",
      "require": "./dist/types.cjs"
    },
    "./wasm": {
      "import": "./dist/wasm.js",
      "require": "./dist/wasm.cjs"
    },
    "./anomaPayArm.wasm": {
      "default": "./dist/arm_bindings_bg.wasm"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "rimraf dist",
    "prebuild": "pnpm clean",
    "build": "pnpm build:wasm && tsdown && pnpm copy:wasm && pnpm pack",
    "build:docs": "typedoc --plugin typedoc-plugin-markdown --out ./docs src/index.ts",
    "dev": "tsdown --watch --on-success 'pnpm copy:wasm'",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,js,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json,css,md}\"",
    "test": "vitest",
    "test:run": "vitest run",
    "build:ts": "tsdown",
    "build:wasm": "node ./scripts/build.mjs --release",
    "build:wasm:dev": "node ./scripts/build.mjs",
    "copy:wasm": "cp ./src/wasm/arm_bindings_bg.wasm ./dist",
    "pack:ci": "npm pack --pack-destination package/",
    "pack:dry-run": "npm pack --dry-run",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@noble/hashes": "1.8.0",
    "@noble/secp256k1": "3.0.0",
    "@uniswap/permit2-sdk": "1.4.0",
    "@wagmi/core": "3.5.2",
    "bs58": "6.0.0",
    "buffer": "6.0.3",
    "crc-32": "1.2.2",
    "viem": "2.53.1",
    "zod": "4.1.13"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.36.0",
    "@types/node": "^24.12.0",
    "eslint": "^9.36.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.6.2",
    "prettier-plugin-organize-imports": "^4.3.0",
    "rimraf": "^6.1.3",
    "tsdown": "^0.21.5",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.6"
  }
}
