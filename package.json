{
  "name": "@anomaorg/anoma-app-sdk",
  "version": "0.9.0",
  "type": "module",
  "main": "dist/index.js",
  "private": false,
  "engines": {
    "node": ">=22"
  },
  "files": [
    "./dist/*",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./api": {
      "import": "./dist/api.mjs",
      "require": "./dist/api.cjs"
    },
    "./constants": {
      "import": "./dist/lib-constants.mjs",
      "require": "./dist/lib-constants.cjs"
    },
    "./domain": {
      "import": "./dist/domain.mjs",
      "require": "./dist/domain.cjs"
    },
    "./lib": {
      "import": "./dist/lib.mjs",
      "require": "./dist/lib.cjs"
    },
    "./types": {
      "import": "./dist/types.mjs",
      "require": "./dist/types.cjs"
    },
    "./wasm": {
      "import": "./dist/wasm.mjs",
      "require": "./dist/wasm.cjs"
    },
    "./anomaPayArm.wasm": {
      "default": "./dist/arm_bindings_bg.wasm"
    },
    "./lib-constants": {
      "import": "./dist/lib-constants.mjs",
      "require": "./dist/lib-constants.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "lint": "eslint .",
    "tsc": "tsc -b",
    "tsc-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,js,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json,css,md}\"",
    "test": "vitest",
    "test:run": "vitest run",
    "build": "tsdown && cp ./src/wasm/arm_bindings_bg.wasm ./dist",
    "build:wasm": "node ./scripts/build.mjs --release",
    "build:wasm:dev": "node ./scripts/build.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@noble/hashes": "1.8.0",
    "@noble/secp256k1": "3.0.0",
    "@uniswap/permit2-sdk": "1.4.0",
    "bs58": "^6.0.0",
    "crc-32": "1.2.2",
    "viem": "2.38.5",
    "zod": "4.1.13"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.36.0",
    "@types/node": "^24.12.0",
    "eslint": "^9.36.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.6.2",
    "prettier-plugin-organize-imports": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.6",
    "tsdown": "^0.21.5"
  }
}
