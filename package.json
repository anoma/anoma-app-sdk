{
  "name": "@anonma/anomapay-sdk",
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/anomapay-sdk.cjs",
  "module": "./dist/anomapay-sdk.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/anomapay-sdk.js",
      "require": "./dist/anomapay-sdk.umd.cjs"
    }
  },
  "scripts": {
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "tsc": "tsc -b",
    "tsc-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json,md}\"",
    "test": "vitest",
    "prepare": "husky",
    "build:wasm": "node ./scripts/build.mjs --release",
    "build:wasm:dev": "node ./scripts/build.mjs"
  },
  "dependencies": {
    "@noble/hashes": "1.8.0",
    "@noble/secp256k1": "3.0.0",
    "@uniswap/permit2-sdk": "1.4.0",
    "crc-32": "1.2.2",
    "viem": "2.38.5",
    "wagmi": "3.1.1",
    "zod": "4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "eslint": "^9.36.0",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "prettier": "^3.6.2",
    "prettier-plugin-organize-imports": "^4.3.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.45.0",
    "vite": "^7.1.7",
    "vite-plugin-dts": "^4.5.4",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.6"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
