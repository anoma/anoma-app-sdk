{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tsbuildinfo",
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "resolveJsonModule": true,
    "noEmit": true,
    "strict": true,
    "preserveSymlinks": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "types": ["vite/client"],
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "api": ["./src/api/index.ts"],
      "api/*": ["./src/api/*"],
      "domain/*": ["./src/domain/*"],
      "lib": ["./src/lib/index.ts"],
      "lib/*": ["./src/lib/*"],
      "wasm": ["./src/wasm/index.ts"],
      "wasm/*": ["./src/wasm/*"],
      "anomaPayLib": ["./src/wasm/anomaPayLib/index.ts"],
      "anomaPayLib/*": ["./src/wasm/anomaPayLib/*"],
      "anomaPayLibV2": ["./src/wasm/anomaPayLibV2/index.ts"],
      "anomaPayLibV2/*": ["./src/wasm/anomaPayLibV2/*"],
      "armRisc0Bindings": ["./src/wasm/armRisc0Bindings/index.ts"],
      "armRisc0Bindings/*": ["./src/wasm/armRisc0Bindings/*"],
      "lib-constants": ["./src/lib-constants.ts"],
      "types": ["./src/types.ts"]
    }
  },
  "include": ["src"]
}
